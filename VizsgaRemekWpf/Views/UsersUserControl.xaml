<UserControl x:Class="VizsgaRemekWpf.Views.UserUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VizsgaRemekWpf.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1A1A24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#13131C"/>
            <Setter Property="Foreground" Value="#6B6B80"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F0EDE8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Felhasználók" FontSize="15" FontWeight="SemiBold"
                               Foreground="#F0EDE8" Margin="0,0,0,14"/>
                    <DataGrid ItemsSource="{Binding Users}" AutoGenerateColumns="False"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="#1A1A24" AlternatingRowBackground="#1F1F2C"
                              Foreground="#F0EDE8" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A2A3A" HeadersVisibility="Column"
                              CanUserAddRows="False" IsReadOnly="True" MaxHeight="350"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              CellStyle="{StaticResource DgCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NÉV" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="FELHASZNÁLÓNÉV" Binding="{Binding UserName}" Width="*"/>
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="PONTOK" Binding="{Binding Points}" Width="90"/>
                            <DataGridTextColumn Header="SZEREP" Binding="{Binding Role}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Top 10 felhasználó pontok szerint" FontSize="13"
                               FontWeight="SemiBold" Foreground="#F0EDE8" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Series="{Binding PointsSeries}"
                                        XAxes="{Binding UsersXAxes}"
                                        YAxes="{Binding DefaultYAxes}" Height="210"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
