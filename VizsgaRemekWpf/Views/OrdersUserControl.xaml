<UserControl x:Class="VizsgaRemekWpf.Views.OrderUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000"
             Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Felső rész -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- Bevétel összesítő -->
            <Border Grid.Column="0"
                    Background="#13131C"
                    CornerRadius="18"
                    Padding="22"
                    BorderBrush="#2A2A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Bevétel összesítő"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#F0EDE8"
                               Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <TextBlock Text="💰" FontSize="20" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Összes bevétel"
                                       FontSize="12"
                                       Foreground="#6B6B80"/>
                            <TextBlock Text="{Binding TotalRevenue}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#A8FF78"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <TextBlock Text="✅" FontSize="20" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Sikeres rendelések"
                                       FontSize="12"
                                       Foreground="#6B6B80"/>
                            <TextBlock Text="{Binding SuccessfulOrders}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4ECDC4"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳" FontSize="20" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Függő rendelések"
                                       FontSize="12"
                                       Foreground="#6B6B80"/>
                            <TextBlock Text="{Binding PendingOrders}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FFB627"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Státusz grafikon -->
            <Border Grid.Column="2"
                    Background="#13131C"
                    CornerRadius="18"
                    Padding="18"
                    BorderBrush="#2A2A3A"
                    BorderThickness="1"
                    MinWidth="340">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Rendelések státusz szerint"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#F0EDE8"
                               Margin="0,0,0,16"/>

                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding StatusSeries}"
                                  Height="260"
                                  Width="300"
                                  LegendPosition="Bottom"
                                  InitialRotation="-90"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Táblázat -->
        <Border Grid.Row="2"
                Background="#13131C"
                CornerRadius="18"
                Padding="18"
                BorderBrush="#2A2A3A"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Rendelések"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#F0EDE8"
                           Margin="0,0,0,16"/>

                <DataGrid ItemsSource="{Binding Orders}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="#13131C"
                          AlternatingRowBackground="#1A1A24"
                          Foreground="#F0EDE8"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2A2A3A"
                          VerticalGridLinesBrush="#2A2A3A"
                          ColumnHeaderHeight="42"
                          RowHeight="40">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A1A24"/>
                            <Setter Property="Foreground" Value="#6B6B80"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#2A2A3A"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#F0EDE8"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RENDELÉS ID"
                                            Binding="{Binding PublicId}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="FELHASZNÁLÓ"
                                            Binding="{Binding UserName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="ÖSSZEG"
                                            Binding="{Binding TotalPrice, StringFormat={}{0:N0} Ft}"
                                            Width="120"/>

                        <DataGridTextColumn Header="STÁTUSZ"
                                            Binding="{Binding Status}"
                                            Width="120"/>

                        <DataGridTextColumn Header="DÁTUM"
                                            Binding="{Binding OrderDate, StringFormat={}{0:yyyy.MM.dd HH:mm}}"
                                            Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>