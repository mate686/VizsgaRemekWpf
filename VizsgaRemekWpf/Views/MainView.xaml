<Window x:Class="VizsgaRemekWpf.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VizsgaRemekWpf.ViewModels"
        xmlns:views="clr-namespace:VizsgaRemekWpf.Views"
        xmlns:conv="clr-namespace:VizsgaRemekWpf.Converters"
        Title="VizsgaRemek Admin" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F14"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:IsSelectedTabConverter x:Key="IsSelectedTab"/>

        
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverViewUserControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RestaurantsViewModel}">
            <views:RestaurantUserControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <views:OrderUserControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UserUserControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReviewsViewModel}">
            <views:ReviewsUserControl/>
        </DataTemplate>

        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B6B80"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF6B3520"/>
                                <Setter Property="Foreground" Value="#FF6B35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1A24"/>
                                <Setter Property="Foreground" Value="#F0EDE8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <views:LoginUserControl DataContext="{Binding LoginVM}">
            <views:LoginUserControl.Style>
                <Style TargetType="views:LoginUserControl">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:LoginUserControl.Style>
        </views:LoginUserControl>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

           
            <Border Grid.Column="0" Background="#13131C"
                    BorderBrush="#2A2A3A" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="20,24,20,28">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF6B35" Offset="0"/>
                                        <GradientStop Color="#FFB627" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🍽" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="VizsgaRemek" FontSize="14"
                                           FontWeight="Bold" Foreground="#F0EDE8"/>
                                <TextBlock Text="Admin Panel" FontSize="10" Foreground="#6B6B80"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button DockPanel.Dock="Bottom" Command="{Binding LogoutCommand}"
                            Margin="8,4,8,16" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent"
                                        CornerRadius="8" Padding="16,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚪" FontSize="14" Margin="0,0,10,0"/>
                                        <TextBlock Text="Kijelentkezés" Foreground="#6B6B80" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#1A1A24"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border DockPanel.Dock="Bottom" Margin="12,0,12,4"
                            Background="#1A1A24" CornerRadius="10" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#FF6B3530" Margin="0,0,10,0">
                                <TextBlock Text="👤" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding AdminUsername}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#F0EDE8"/>
                                <TextBlock Text="Administrator" FontSize="11" Foreground="#FF6B35"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="12,0">
                        <TextBlock Text="NAVIGÁCIÓ" FontSize="10" Foreground="#3A3A50"
                                   FontWeight="SemiBold" Margin="8,0,0,10"/>

                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Command="{Binding SelectTabCommand}"
                                     CommandParameter="{Binding Tabs[0]}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource IsSelectedTab}" Mode="OneWay">
                                    <Binding Path="Tabs[0]"/>
                                    <Binding Path="SelectedTab"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0"/>
                                <TextBlock Text="Áttekintés" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Margin="0,2,0,0"
                                     Command="{Binding SelectTabCommand}"
                                     CommandParameter="{Binding Tabs[1]}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource IsSelectedTab}" Mode="OneWay">
                                    <Binding Path="Tabs[1]"/>
                                    <Binding Path="SelectedTab"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏪" FontSize="15" Margin="0,0,10,0"/>
                                <TextBlock Text="Éttermek" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Margin="0,2,0,0"
                                     Command="{Binding SelectTabCommand}"
                                     CommandParameter="{Binding Tabs[2]}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource IsSelectedTab}" Mode="OneWay">
                                    <Binding Path="Tabs[2]"/>
                                    <Binding Path="SelectedTab"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="15" Margin="0,0,10,0"/>
                                <TextBlock Text="Rendelések" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Margin="0,2,0,0"
                                     Command="{Binding SelectTabCommand}"
                                     CommandParameter="{Binding Tabs[3]}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource IsSelectedTab}" Mode="OneWay">
                                    <Binding Path="Tabs[3]"/>
                                    <Binding Path="SelectedTab"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="15" Margin="0,0,10,0"/>
                                <TextBlock Text="Felhasználók" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavBtn}" GroupName="Nav"
                                     Margin="0,2,0,0"
                                     Command="{Binding SelectTabCommand}"
                                     CommandParameter="{Binding Tabs[4]}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource IsSelectedTab}" Mode="OneWay">
                                    <Binding Path="Tabs[4]"/>
                                    <Binding Path="SelectedTab"/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭐" FontSize="15" Margin="0,0,10,0"/>
                                <TextBlock Text="Értékelések" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border VerticalAlignment="Top" Height="60" Background="#13131C"
                        BorderBrush="#2A2A3A" BorderThickness="0,0,0,1" Panel.ZIndex="10">
                    <DockPanel Margin="24,0">
                        <TextBlock Text="{Binding SelectedTab.Title}" FontSize="19"
                                   FontWeight="Bold" Foreground="#F0EDE8" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LastUpdated}" Foreground="#6B6B80"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Button Command="{Binding RefreshCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#1A1A24" CornerRadius="8"
                                                BorderBrush="#2A2A3A" BorderThickness="1" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔄" Margin="0,0,6,0"/>
                                                <TextBlock Text="Frissítés" Foreground="#F0EDE8" FontSize="13"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#22222F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Background="#CC000000" Panel.ZIndex="20"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳ Betöltés..." Foreground="#F0EDE8" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

           
                <ContentControl Content="{Binding SelectedTab}" Margin="0,60,0,0"/>
            </Grid>
        </Grid>
    </Grid>

</Window>

